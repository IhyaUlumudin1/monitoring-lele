{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/proses-login.php", "dest": "/proses-login.php" },
    { "src": "/login.php", "dest": "/login.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
