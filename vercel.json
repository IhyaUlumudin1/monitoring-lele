{
  "builds": [
    {
      "src": "api/**/*.php",
      "use": "vercel-php@0.7.3"
    },
    {
      "src": "*.php",
      "use": "vercel-php@0.7.3"
    },
    {
      "src": "*.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
